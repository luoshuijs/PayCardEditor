<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Material 3 color scheme — light.
        Derived from existing brand seeds:
          jade   (#1F7A5A) → primary
          amber  (#A66A15) → secondary
          coral  (#AF4F3D) → tertiary / error accent
        Token names follow the M3 spec; theme attrs map to these in themes.xml.
    -->

    <!-- Primary — jade -->
    <color name="md_primary">#1F7A5A</color>
    <color name="md_on_primary">#FFFFFF</color>
    <color name="md_primary_container">#A6F2D2</color>
    <color name="md_on_primary_container">#002115</color>

    <!-- Secondary — amber -->
    <color name="md_secondary">#7A5318</color>
    <color name="md_on_secondary">#FFFFFF</color>
    <color name="md_secondary_container">#FFDDB1</color>
    <color name="md_on_secondary_container">#291800</color>

    <!-- Tertiary — coral -->
    <color name="md_tertiary">#8C4434</color>
    <color name="md_on_tertiary">#FFFFFF</color>
    <color name="md_tertiary_container">#FFDAD1</color>
    <color name="md_on_tertiary_container">#3A0A02</color>

    <!-- Error -->
    <color name="md_error">#BA1A1A</color>
    <color name="md_on_error">#FFFFFF</color>
    <color name="md_error_container">#FFDAD6</color>
    <color name="md_on_error_container">#410002</color>

    <!-- Surface tier (M3 Expressive) -->
    <color name="md_background">#F4F0E8</color>
    <color name="md_on_background">#172126</color>
    <color name="md_surface">#FBF8F1</color>
    <color name="md_on_surface">#172126</color>
    <color name="md_surface_variant">#E1E3DC</color>
    <color name="md_on_surface_variant">#5E6A70</color>
    <color name="md_surface_dim">#DDD9D2</color>
    <color name="md_surface_bright">#FBF8F1</color>
    <color name="md_surface_container_lowest">#FFFFFF</color>
    <color name="md_surface_container_low">#F6F2EA</color>
    <color name="md_surface_container">#F0EDE5</color>
    <color name="md_surface_container_high">#EAE6DE</color>
    <color name="md_surface_container_highest">#E4E1D9</color>

    <!-- Outline -->
    <color name="md_outline">#79747E</color>
    <color name="md_outline_variant">#CFD2C8</color>

    <!-- Inverse -->
    <color name="md_inverse_surface">#2C3236</color>
    <color name="md_inverse_on_surface">#EEEFEA</color>
    <color name="md_inverse_primary">#8AD8B6</color>
</resources>
